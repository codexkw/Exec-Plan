@*
    Self-hosted inline-SVG icon (NFR-6: no CDN, no icon-font download for ~16 glyphs).
    Usage: <partial name="_Icon" model="dashboard" />  — Material-style 24-grid line icons.
    Styling/size comes from the .ep-i class in execplan.css (stroke = currentColor).
*@
@model string
@{
    string paths = Model switch
    {
        "dashboard"     => "<rect x='3' y='3' width='7' height='9' rx='1.5'/><rect x='14' y='3' width='7' height='5' rx='1.5'/><rect x='14' y='12' width='7' height='9' rx='1.5'/><rect x='3' y='16' width='7' height='5' rx='1.5'/>",
        "plans"         => "<rect x='4' y='4' width='16' height='17' rx='2'/><path d='M8.5 3.5h7a1 1 0 0 1 1 1V6a1 1 0 0 1-1 1h-7a1 1 0 0 1-1-1V4.5a1 1 0 0 1 1-1Z'/><path d='M8 11.5h8M8 15.5h5'/>",
        "users"         => "<circle cx='9' cy='8' r='3'/><path d='M3.5 20a5.5 5.5 0 0 1 11 0'/><path d='M16 5.4a3 3 0 0 1 0 5.9'/><path d='M17.5 14.6a5.5 5.5 0 0 1 3 4.9'/>",
        "departments"   => "<rect x='5' y='3' width='14' height='18' rx='1.5'/><path d='M9 7h2M13 7h2M9 11h2M13 11h2M9 15h2M13 15h2'/><path d='M5 21h14'/>",
        "organizations" => "<path d='M3 21h18'/><rect x='4' y='8' width='7' height='13' rx='1'/><rect x='13' y='4' width='7' height='17' rx='1'/><path d='M7 12h1M7 16h1M16 8h1M16 12h1M16 16h1'/>",
        "activations"   => "<path d='M13 2 4 14h7l-1 8 9-12h-7l1-8Z'/>",
        "logout"        => "<path d='M15 4h3a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2h-3'/><path d='M10 17l5-5-5-5'/><path d='M15 12H3'/>",
        "translate"     => "<path d='M4 5h9'/><path d='M8 3v2c0 4-2 8-5 10'/><path d='M6 9c1.5 3 4 5 7 6'/><path d='M13 21l4-9 4 9'/><path d='M14.5 18h5'/>",
        "menu"          => "<path d='M4 6h16M4 12h16M4 18h16'/>",
        "bell"          => "<path d='M18 8a6 6 0 1 0-12 0c0 7-3 8-3 8h18s-3-1-3-8'/><path d='M10.4 21a1.8 1.8 0 0 0 3.2 0'/>",
        "add"           => "<path d='M12 5v14M5 12h14'/>",
        "launch"        => "<path d='M12 3c3 1.6 5 4.6 5 8.2L14.5 14h-5L7 11.2C7 7.6 9 4.6 12 3Z'/><circle cx='12' cy='9' r='1.4'/><path d='M9.5 16 8 20.5l3-1.6M14.5 16 16 20.5l-3-1.6'/>",
        "check"         => "<path d='M4 12.5 9 17.5 20 6.5'/>",
        "warning"       => "<path d='M12 4 2.6 20h18.8L12 4Z'/><path d='M12 10v5M12 18h.01'/>",
        "clock"         => "<circle cx='12' cy='12' r='8.5'/><path d='M12 7.5V12l3 2'/>",
        "close"         => "<path d='M6 6l12 12M18 6 6 18'/>",
        "chart"         => "<path d='M4 4v16h16'/><path d='M8 16v-4M12 16V8M16 16v-6'/>",
        "shield"        => "<path d='M12 3 5 6v5c0 4.5 3 8 7 9 4-1 7-4.5 7-9V6l-7-3Z'/><path d='M9 12l2 2 4-4'/>",
        _               => "<circle cx='12' cy='12' r='9'/>",
    };
}
<svg class="ep-i" viewBox="0 0 24 24" role="img" aria-hidden="true" focusable="false">@Html.Raw(paths.Replace("'", "\""))</svg>
