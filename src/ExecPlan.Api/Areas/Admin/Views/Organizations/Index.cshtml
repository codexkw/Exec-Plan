@model ExecPlan.Api.Areas.Admin.Models.OrgListVm

<div class="ep-page-head">
  <h1>@Localizer["Org.Title"]</h1>
  @if (Model.CanWrite)
  {
    <div class="ep-actions">
      <a class="btn btn-primary ep-primary ep-btn-i" href="/admin/organizations/create">
        <partial name="_Icon" model="@("add")" /> @Localizer["Org.Add"]
      </a>
    </div>
  }
</div>

@if (!Model.Organizations.Any())
{
  <div class="ep-card"><div class="ep-empty">
    <partial name="_Icon" model="@("organizations")" />
    <div>—</div>
  </div></div>
}
else
{
  <div class="table-responsive">
    <table class="ep-table">
      <thead>
        <tr>
          <th>@Localizer["Org.Name"]</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var o in Model.Organizations)
        {
          <tr>
            <td class="fw-semibold">@o.Name</td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}
