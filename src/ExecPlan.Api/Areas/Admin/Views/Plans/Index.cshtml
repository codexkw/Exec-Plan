@model ExecPlan.Api.Areas.Admin.Models.PlanListVm
@using ExecPlan.Domain.Enums
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h4 mb-0">@Localizer["Plans.Title"]</h1>
  <a class="btn btn-primary ep-primary" href="/admin/plans/create">@Localizer["Plans.New"]</a>
</div>
<div class="ep-card p-3">
  @if (!Model.Plans.Any())
  {
    <p class="text-muted mb-0">@Localizer["Plans.NoPlans"]</p>
  }
  else
  {
    <table class="table">
      <thead>
        <tr>
          <th>@Localizer["Plans.Name"]</th>
          <th>@Localizer["Plans.Type"]</th>
          <th>@Localizer["Plans.Status"]</th>
          <th>@Localizer["Common.Actions"]</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var p in Model.Plans)
        {
          <tr>
            <td><a href="/admin/plans/@p.Id">@p.Name</a></td>
            <td>@Localizer["PlanType." + p.Type]</td>
            <td>
              @if (p.Status == PlanStatus.Draft)
              {
                <span class="badge badge-draft">@Localizer["Status.Draft"]</span>
              }
              else
              {
                <span class="badge badge-ready">@Localizer["Status.Ready"]</span>
              }
            </td>
            <td>
              @if (p.ActiveActivationId is Guid activationId)
              {
                <a href="/admin/activations/@activationId">@Localizer["Plans.WatchDashboard"]</a>
              }
            </td>
          </tr>
        }
      </tbody>
    </table>
  }
</div>
