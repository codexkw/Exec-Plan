@model ExecPlan.Api.Areas.Admin.Models.PlanListVm
@using ExecPlan.Domain.Enums

<div class="ep-page-head">
  <h1>@Localizer["Plans.Title"]</h1>
  <div class="ep-actions">
    <a class="btn btn-primary ep-primary ep-btn-i" href="/admin/plans/create">
      <partial name="_Icon" model="@("add")" /> @Localizer["Plans.New"]
    </a>
  </div>
</div>

@if (!Model.Plans.Any())
{
  <div class="ep-card"><div class="ep-empty">
    <partial name="_Icon" model="@("plans")" />
    <div>@Localizer["Plans.NoPlans"]</div>
  </div></div>
}
else
{
  <div class="table-responsive">
    <table class="ep-table">
      <thead>
        <tr>
          <th>@Localizer["Plans.Name"]</th>
          <th>@Localizer["Plans.Type"]</th>
          <th>@Localizer["Plans.Status"]</th>
          <th>@Localizer["Common.Actions"]</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var p in Model.Plans)
        {
          <tr>
            <td class="fw-semibold"><a href="/admin/plans/@p.Id">@p.Name</a></td>
            <td>@Localizer["PlanType." + p.Type]</td>
            <td>
              @if (p.Status == PlanStatus.Draft)
              {
                <span class="badge-draft">@Localizer["Status.Draft"]</span>
              }
              else
              {
                <span class="badge-ready">@Localizer["Status.Ready"]</span>
              }
            </td>
            <td>
              @if (p.ActiveActivationId is Guid activationId)
              {
                <a class="ep-btn-i" href="/admin/activations/@activationId">
                  @Localizer["Plans.WatchDashboard"] <partial name="_Icon" model="@("chart")" />
                </a>
              }
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}
