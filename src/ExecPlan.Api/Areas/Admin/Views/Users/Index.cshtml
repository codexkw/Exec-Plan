@model ExecPlan.Api.Areas.Admin.Models.UserListVm

<div class="ep-page-head">
  <h1>@Localizer["Users.Title"]</h1>
  @if (Model.CanWrite)
  {
    <div class="ep-actions">
      <a class="btn btn-primary ep-primary ep-btn-i" href="/admin/users/create">
        <partial name="_Icon" model="@("add")" /> @Localizer["Users.Add"]
      </a>
    </div>
  }
</div>

<div class="table-responsive">
  <table class="ep-table">
    <thead>
      <tr>
        <th>@Localizer["Login.UserName"]</th>
        <th>@Localizer["Users.FullName"]</th>
        <th>@Localizer["Users.Role"]</th>
        <th>@Localizer["Users.Department"]</th>
        <th>@Localizer["Users.Active"]</th>
        @if (Model.CanWrite)
        {
          <th>@Localizer["Common.Actions"]</th>
        }
      </tr>
    </thead>
    <tbody>
      @foreach (var u in Model.Users)
      {
        <tr>
          <td class="fw-semibold">@u.UserName</td>
          <td>@u.FullName</td>
          <td>@Localizer["Role." + u.Role]</td>
          <td>@u.Department</td>
          <td>
            @if (u.IsActive)
            {
              <span class="badge-active">@Localizer["Users.Active"]</span>
            }
            else
            {
              <span class="badge-inactive">@Localizer["Common.No"]</span>
            }
          </td>
          @if (Model.CanWrite)
          {
            <td><a href="/admin/users/@u.Id/edit">@Localizer["Common.Edit"]</a></td>
          }
        </tr>
      }
    </tbody>
  </table>
</div>
