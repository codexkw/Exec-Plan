@{
    var active = ViewData["step"] as int? ?? 1;
    var steps = new[] { "Wizard.Step1", "Wizard.Step2", "Wizard.Step3", "Wizard.Step4" };
}
<ol class="ep-wizard-steps d-flex list-unstyled gap-3 mb-4">
    @for (var i = 0; i < steps.Length; i++)
    {
        var n = i + 1;
        <li class="ep-wizard-step @(n == active ? "active fw-bold" : "text-muted")">
            @n. @Localizer[steps[i]]
        </li>
    }
</ol>
