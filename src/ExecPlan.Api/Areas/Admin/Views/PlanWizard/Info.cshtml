@model ExecPlan.Api.Areas.Admin.Models.WizardInfoVm
@using ExecPlan.Domain.Enums
@{
    // Edit flow when a plan id is present (posts to {id}/info and updates in place); create flow otherwise.
    var planId = ViewData["planId"] as Guid?;
    var formAction = planId is Guid pid ? $"/admin/plans/create/{pid}/info" : "/admin/plans/create";
}
<h1 class="h4 mb-3">@(planId is null ? Localizer["Plans.New"] : Localizer["Plans.Edit"])</h1>
<partial name="_Steps" />
<div class="ep-card p-4">
  <form method="post" action="@formAction">
    @Html.AntiForgeryToken()
    <partial name="_ValidationSummary" />
    <div class="mb-3">
      <label class="form-label">@Localizer["Plans.Name"]</label>
      <input class="form-control" name="Name" value="@Model.Name" required/>
    </div>
    <div class="mb-3">
      <label class="form-label">@Localizer["Plans.Type"]</label>
      <select class="form-select" name="Type">
        @foreach (var t in Enum.GetValues<PlanType>())
        {
          <option value="@t" selected="@(t == Model.Type)">@Localizer["PlanType." + t]</option>
        }
      </select>
    </div>
    <div class="mb-3">
      <label class="form-label">@Localizer["Plans.Objective"]</label>
      <textarea class="form-control" name="Objective">@Model.Objective</textarea>
    </div>
    <div class="mb-3">
      <label class="form-label">@Localizer["Plans.Description"]</label>
      <textarea class="form-control" name="Description">@Model.Description</textarea>
    </div>
    <div class="mb-3">
      <label class="form-label">@Localizer["Plans.Scope"]</label>
      <textarea class="form-control" name="Scope">@Model.Scope</textarea>
    </div>
    <button class="btn btn-primary ep-primary" type="submit">@Localizer["Wizard.Next"]</button>
  </form>
</div>
