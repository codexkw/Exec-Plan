@model ExecPlan.Api.Areas.Admin.Models.LeaderActivationsVm

<div class="ep-page-head">
  <h1>@Localizer["Activations.Title"]</h1>
</div>

@if (!Model.Activations.Any())
{
  <div class="ep-card"><div class="ep-empty">
    <partial name="_Icon" model="@("activations")" />
    <div>@Localizer["Activations.Empty"]</div>
  </div></div>
}
else
{
  <div class="table-responsive">
    <table class="ep-table">
      <thead>
        <tr>
          <th>@Localizer["Review.Shift"]</th>
          <th>@Localizer["Review.Date"]</th>
          <th>@Localizer["Common.Actions"]</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var a in Model.Activations)
        {
          <tr>
            <td class="fw-semibold">@Localizer["Shift." + a.Shift]</td>
            <td>@a.RosterDate.ToString("yyyy-MM-dd")</td>
            <td>
              <a class="ep-btn-i" href="/admin/activations/@a.Id">
                @Localizer["Plans.WatchDashboard"] <partial name="_Icon" model="@("chart")" />
              </a>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}
