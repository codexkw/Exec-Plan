@model ExecPlan.Api.Areas.Admin.Models.DashboardVm
@using ExecPlan.Domain.Enums
<div data-activation-id="@Model.Dto.ActivationId">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">@Localizer["Dash.Title"]</h1>
    <a class="btn btn-secondary" href="/admin">@Localizer["Common.Back"]</a>
  </div>

  <div class="row mb-3 g-3">
    <div class="col">
      <div class="counter-tile" data-counter="total" data-value="@Model.Dto.TotalParticipants">
        <div class="n">@Model.Dto.TotalParticipants</div>
        <div class="lbl">@Localizer["Dash.Total"]</div>
      </div>
    </div>
    <div class="col">
      <div class="counter-tile" data-counter="pending" data-value="@Model.Dto.PendingCount">
        <div class="n">@Model.Dto.PendingCount</div>
        <div class="lbl">@Localizer["Dash.Pending"]</div>
      </div>
    </div>
    <div class="col">
      <div class="counter-tile ready" data-counter="ready" data-value="@Model.Dto.ReadyCount">
        <div class="n">@Model.Dto.ReadyCount</div>
        <div class="lbl">@Localizer["Dash.Ready"]</div>
      </div>
    </div>
    <div class="col">
      <div class="counter-tile escalated" data-counter="escalated" data-value="@Model.Dto.EscalatedCount">
        <div class="n">@Model.Dto.EscalatedCount</div>
        <div class="lbl">@Localizer["Dash.Escalated"]</div>
      </div>
    </div>
    <div class="col">
      <div class="counter-tile" data-counter="inducted" data-value="@Model.Dto.InductedCount">
        <div class="n">@Model.Dto.InductedCount</div>
        <div class="lbl">@Localizer["Dash.Inducted"]</div>
      </div>
    </div>
  </div>

  <div class="ep-card p-3 mb-3 d-flex gap-4">
    <div>
      <strong>@Localizer["Dash.ResponseRate"]</strong>:
      <span data-rate="response">@((int)Math.Round(Model.Dto.ResponseRate * 100))%</span>
    </div>
    <div>
      <strong>@Localizer["Dash.TaskRate"]</strong>:
      <span data-rate="task">@((int)Math.Round(Model.Dto.TaskCompletionRate * 100))%</span>
    </div>
  </div>

  @if (TempData["toast"] is string toast)
  {
    <div class="alert alert-info" role="alert" data-toast="true">@Localizer["Dash.ToastPrefix"]: @toast</div>
  }

  @* Action bar: real antiforgery-protected POST forms (Task 15) — run-escalation/broadcast/close.
     Gated on CanAct (SystemAdmin/PlanManager) and the activation still being Active. *@
  @if (Model.CanAct && Model.Dto.Status == ActivationStatus.Active)
  {
    <div class="d-flex gap-2 mb-3" data-action-bar="true">
      <form method="post" action="/admin/activations/@Model.Dto.ActivationId/run-escalation" class="d-inline">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-secondary">@Localizer["Dash.Escalate"]</button>
      </form>

      <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#broadcastModal">@Localizer["Dash.Broadcast"]</button>

      <form method="post" action="/admin/activations/@Model.Dto.ActivationId/close" class="d-inline"
            onsubmit="return confirm('@Localizer["Dash.CloseConfirm"]');">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-danger">@Localizer["Dash.Close"]</button>
      </form>
    </div>

    <div class="modal fade" id="broadcastModal" tabindex="-1" aria-hidden="true" aria-labelledby="broadcastModalLabel">
      <div class="modal-dialog">
        <div class="modal-content">
          <form method="post" action="/admin/activations/@Model.Dto.ActivationId/broadcast">
            @Html.AntiForgeryToken()
            <div class="modal-header">
              <h5 class="modal-title" id="broadcastModalLabel">@Localizer["Dash.Broadcast"]</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <label class="form-label" for="broadcastBody">@Localizer["Dash.BroadcastBody"]</label>
              <textarea id="broadcastBody" name="body" class="form-control" rows="4" required></textarea>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Common.Cancel"]</button>
              <button type="submit" class="btn btn-primary">@Localizer["Dash.Send"]</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  }

  <h2 class="h5">@Localizer["Dash.Teams"]</h2>
  @if (!Model.Dto.Teams.Any())
  {
    <p class="text-muted">@Localizer["Plans.NoTeams"]</p>
  }
  else
  {
    <table class="table ep-card">
      <thead>
        <tr>
          <th>@Localizer["Dash.Teams"]</th>
          <th>@Localizer["Plans.Members"]</th>
          <th>@Localizer["Dash.Ready"]</th>
          <th>@Localizer["Dash.TaskRate"]</th>
        </tr>
      </thead>
      <tbody>
        @{
          var teamCount = Model.Dto.Teams.Count;
        }
        @for (var i = 0; i < teamCount; i++)
        {
          var t = Model.Dto.Teams[i];
          // Teams is already Score-descending from the service — rendered in that exact order,
          // never re-sorted here. First row = best-performing, last row (when >1 team) = most delayed.
          var rankClass = i == 0 ? "rank-best" : (i == teamCount - 1 && teamCount > 1 ? "rank-delayed" : "");
          <tr class="@rankClass" data-team="@t.TeamName">
            <td>@t.TeamName</td>
            <td>@t.Members</td>
            <td>@t.ReadyCount</td>
            <td>@t.TasksDone / @t.TasksTotal</td>
          </tr>
        }
      </tbody>
    </table>
  }

  <h2 class="h5">@Localizer["Dash.Overdue"]</h2>
  @if (!Model.Dto.Overdue.Any())
  {
    <p class="text-muted">&mdash;</p>
  }
  else
  {
    <ul class="list-group mb-3">
      @foreach (var o in Model.Dto.Overdue)
      {
        <li class="list-group-item text-danger">@o.Title</li>
      }
    </ul>
  }

  <h2 class="h5">@Localizer["Dash.Events"]</h2>
  @if (!Model.Dto.Events.Any())
  {
    <p class="text-muted">&mdash;</p>
  }
  else
  {
    <ul class="list-group">
      @foreach (var e in Model.Dto.Events)
      {
        <li class="list-group-item">@e.Text</li>
      }
    </ul>
  }
</div>

@section scripts {
  <script src="/lib/signalr/signalr.min.js"></script>
  <script src="/js/dashboard.js"></script>
}
