@model ExecPlan.Api.Areas.Admin.Models.DeptListVm

<div class="ep-page-head">
  <h1>@Localizer["Dept.Title"]</h1>
  @if (Model.CanWrite)
  {
    <div class="ep-actions">
      <a class="btn btn-primary ep-primary ep-btn-i" href="/admin/departments/create">
        <partial name="_Icon" model="@("add")" /> @Localizer["Dept.Add"]
      </a>
    </div>
  }
</div>

@if (!Model.Departments.Any())
{
  <div class="ep-card"><div class="ep-empty">
    <partial name="_Icon" model="@("departments")" />
    <div>—</div>
  </div></div>
}
else
{
  <div class="table-responsive">
    <table class="ep-table">
      <thead>
        <tr>
          <th>@Localizer["Dept.Name"]</th>
          <th>@Localizer["Users.Organization"]</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var d in Model.Departments)
        {
          <tr>
            <td class="fw-semibold">@d.Name</td>
            <td>@d.Organization</td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}
