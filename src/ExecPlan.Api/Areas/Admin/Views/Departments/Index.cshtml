@model ExecPlan.Api.Areas.Admin.Models.DeptListVm
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h4 mb-0">@Localizer["Dept.Title"]</h1>
  @if (Model.CanWrite)
  {
    <a class="btn btn-primary ep-primary" href="/admin/departments/create">@Localizer["Dept.Add"]</a>
  }
</div>
<div class="ep-card p-3">
  <table class="table">
    <thead>
      <tr>
        <th>@Localizer["Dept.Name"]</th>
        <th>@Localizer["Users.Organization"]</th>
      </tr>
    </thead>
    <tbody>
      @foreach (var d in Model.Departments)
      {
        <tr>
          <td>@d.Name</td>
          <td>@d.Organization</td>
        </tr>
      }
    </tbody>
  </table>
</div>
